cat("      INTERPRETATION OF ABSOLUTE RECONSTRUCTION           \n")
cat("==========================================================\n")

# 1. CERTAINTY EVALUATION BASED ON ANCHOR RATIO
min_anchor_count <- min(anchors_count)
anchor_ratio <- min_anchor_count / n_t

cat(sprintf("Total Taxa: %d | Min Valid Anchors: %.1f\n", n_t, min_anchor_count))
cat(sprintf("Anchor Consensus Ratio: %.1f%%\n", anchor_ratio * 100))

# 2. DIAGNOSTIC INTERPRETATION
cat("\n[DIAGNOSTIC SUMMARY]\n")

if (anchor_ratio >= 0.5) {
    cat("STATUS: HIGHLY ROBUST CONSENSUS\n")
    cat("INTERPRETATION: A clear majority of taxa support the 'Invariant Absolute Quantity' hypothesis.\n")
    cat("The convergence of the intersection to 1.0 is statistically overwhelming.\n")
} else if (anchor_ratio >= 0.3) {
    cat("STATUS: MODERATE CONSENSUS\n")
    cat("INTERPRETATION: A significant portion of the community remains stable.\n")
    cat("The reconstruction is reliable, though biological variance is present in some taxa.\n")
} else {
    cat("STATUS: LOW CONSENSUS / INDETERMINATE\n")
    cat("WARNING: Few stable anchors detected. The absolute scale is difficult to fix.\n")
}

# 3. DIAGNOSTIC INTERPRETATION
cat("\n[DIAGNOSTIC SUMMARY]\n")

if (anchor_ratio >= 0.5) {
    cat("STATUS: HIGHLY ROBUST CONSENSUS\n")
    cat("INTERPRETATION: A clear majority of taxa support the 'Invariant Absolute Quantity' hypothesis.\n")
