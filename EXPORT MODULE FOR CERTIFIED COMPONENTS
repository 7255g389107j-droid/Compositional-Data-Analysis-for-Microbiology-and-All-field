# 1. Final Validation of Physical Coherence (Rho)
if (result$rho > 0.90) {
  
  cat("\n[STATUS] Physical Coherence Test: PASSED (Rho =", round(result$rho, 6), ")\n")
  
  # 2. Identify Certified Components 
  # (Stable taxa remaining after stripping top IR drivers)
  certified_taxa_names <- colnames(result$cleansed_data)
  
  # 3. Extract Raw Data for Certified Components
  # Note: These components have already cleared the 10x systemic noise floor.
  P_raw <- as.matrix(Dataset)
  P_certified_raw <- P_raw[, certified_taxa_names, drop = FALSE]
  
  # 4. Define Output Filenames
  filename_raw  <- "ITAGAKI_V18_CERTIFIED_RAW_DATA.csv"
  filename_meta <- "ITAGAKI_V18_CERTIFIED_METADATA.csv"
  
  # 5. Export Raw Data (Rows = Samples, Columns = Components)
  write.csv(P_certified_raw, filename_raw, row.names = TRUE)
  
  # 6. Generate and Export Metadata (Certificate of Reliability)
  certified_metadata <- data.frame(
    Component_Name = certified_taxa_names,
    Baseline_IR    = round(result$ir_full[certified_taxa_names], 4),
    Reliability    = "PHYSICALLY_CERTIFIED",
    System_Rho     = round(result$rho, 6)
  )
  write.csv(certified_metadata, filename_meta, row.names = FALSE)
  
  cat("----------------------------------------------------------\n")
  cat(sprintf("SUCCESS: %d components designated as 'Physically Certified'.\n", length(certified_taxa_names)))
  cat(sprintf("Data Exported to      : %s\n", filename_raw))
  cat(sprintf("Metadata Exported to  : %s\n", filename_meta))
  cat("----------------------------------------------------------\n")
  
} else {
  
  cat("\n[WARNING] Physical Coherence below critical threshold (Rho <= 0.90).\n")
  cat("The system is physically sensitive to outliers. Export aborted to maintain data integrity.\n")
  
}
