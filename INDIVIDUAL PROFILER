my_colors <- c("#E0E0E0", "#F1C40F", "#2C3E50")

# Adjust margins for labels
par(mar = c(10, 8, 4, 10))

# Base R image function (Transpose matrix because image() plots rows on x-axis)
image(1:ncol(Rel_Mat), 1:nrow(Rel_Mat), t(Rel_Mat),
      col = my_colors,
      breaks = c(-0.5, 0.5, 1.5, 2.5), # Define boundaries for discrete categories
      xaxt = "n", yaxt = "n",
      xlab = "", ylab = "",
      main = "Individual Reliability Heatmap")

# Add Axes
axis(1, at = 1:ncol(Rel_Mat), labels = colnames(Rel_Mat), las = 2, cex.axis = 0.7)
axis(2, at = 1:nrow(Rel_Mat), labels = rownames(Rel_Mat), las = 1, cex.axis = 0.8)

# Add Legend
legend(x = ncol(Rel_Mat) * 1.05, y = nrow(Rel_Mat),
       legend = c("Reliable (>=10x Floor)", "Uncertain (Presence)", "Absent (Zero)"),
       fill = rev(my_colors),
       xpd = TRUE, bty = "n", cex = 0.8)

# Add grid lines for clarity
grid(nx = ncol(Rel_Mat), ny = nrow(Rel_Mat), col = "white", lty = 1, lwd = 0.5)

