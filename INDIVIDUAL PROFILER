# --- 1. RELIABILITY MATRIX GENERATION ---
# 0: Absent, 1: Uncertain, 2: Reliable
Rel_Mat <- matrix(0, nrow = nrow(P_raw), ncol = ncol(P_raw),
                  dimnames = list(rownames(P_raw), colnames(P_raw)))

for(i in 1:nrow(P_raw)) {
  current_sample <- P_raw[i, ]
  obs_vals <- current_sample[current_sample > 0]
  
  if(length(obs_vals) > 0) {
    floor_i <- min(obs_vals) # 1 / (1/min) is just min
    safety_margin <- floor_i * 10
    
    # Logic Assignment
    Rel_Mat[i, current_sample > 0] <- 1
    Rel_Mat[i, current_sample >= safety_margin] <- 2
  }
}

# --- 2. VISUALIZATION (BASE R) ---
